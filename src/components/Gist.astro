---
const { id } = Astro.props;
const [user, gistId] = id.split('/');
const gistScriptUrl = `https://gist.github.com/${user}/${gistId}.js`;
const gistUrl = `https://gist.github.com/${user}/${gistId}`;
const codeFontStack =
  'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace';
---

<iframe
  style="width: 100%; border: none; min-height: 600px;"
  srcdoc={`<!DOCTYPE html>
<html>
  <head>
    <base target="_blank">
  </head>
  <body style="margin:0;">
    <script src="${gistScriptUrl}"></script>
    <style>
      .gist,
      .gist .blob-code,
      .gist .blob-code-inner,
      .gist .blob-num,
      .gist .highlight,
      .gist .highlight pre,
      .gist table {
        font-family: ${codeFontStack} !important;
      }

      .gist .blob-code,
      .gist .blob-code-inner,
      .gist .blob-num {
        font-size: 14px !important;
        line-height: 1.55 !important;
      }
    </style>
  </body>
</html>`}>
</iframe>

<div style="
  text-align: center;
  margin-top: 0.25rem;
  font-size: 0.75rem;
  color: #777;
">
  <a
    href={gistUrl}
    target="_blank"
    rel="noopener noreferrer"
    style="text-decoration: none; color: inherit;"
  >
    Ver código en GitHub Gist →
  </a>
</div>
