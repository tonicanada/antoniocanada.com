---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PaginatedList from "../../components/PaginatedList.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("erpnext");
  posts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
---

<BaseLayout title="ERPNext" sideBarActiveItemID="erpnext">
  <!-- Sección personalizada con presentación -->
  <section class="max-w-5xl mx-auto p-6">
    <h1 class="text-3xl font-bold mb-4">ERPNext</h1>
    <p class="mb-6 text-lg">
      En esta sección te presento ERPNext, un sistema ERP de código abierto para
      gestionar todas las áreas de tu empresa. Aquí tienes un video
      introductorio que preparé para explicar sus beneficios y funcionalidades.
    </p>

    <div
      class="aspect-w-16 aspect-h-9 w-full rounded-lg shadow-lg overflow-hidden mb-6"
    >
      <iframe
        src="https://www.youtube.com/embed/kgBMb0ijOmM"
        title="Presentación ERPNext"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        class="w-full h-full border-0"
      ></iframe>
    </div>

    <p class="text-base mb-10">
      Próximamente agregaré más recursos y tutoriales para ayudarte a
      implementar ERPNext en tu empresa.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-12">
    <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-semibold mb-3">ERPNext + IA en acción</h2>
      <p class="text-base text-gray-700 mb-6">
        Demo rápida de automatización sobre ERPNext: emitir una factura y
        enviarla por email con OpenClaw.
      </p>

      <div class="mx-auto w-full max-w-[400px]">
        <div
          class="relative w-full overflow-hidden rounded-lg bg-black shadow-lg aspect-[9/16]"
          data-short-hover-player
        >
          <iframe
            data-short-iframe
            class="absolute inset-0 h-full w-full border-0"
            src="https://www.youtube-nocookie.com/embed/vG_Yv2dNY38?rel=0&mute=1&playsinline=1"
            title="ERPNext + IA en acción"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- Lista paginada de artículos -->
  <PaginatedList
    title="Artículos"
    urlPrefix="/erpnext"
    page={page}
    cardProps={(entry) => ({
      title: entry.data.title,
      desc: entry.data.description,
      img: entry.data.image,
      url: "/erpnext/" + createSlug(entry.data.title, entry.slug),
      badge: entry.data.badge,
      tags: entry.data.tags,
    })}
  />

  <script>
    const player = document.querySelector("[data-short-hover-player]");
    const iframe = player?.querySelector("[data-short-iframe]");

    if (player instanceof HTMLElement && iframe instanceof HTMLIFrameElement) {
      const baseSrc = "https://www.youtube-nocookie.com/embed/vG_Yv2dNY38?rel=0&mute=1&playsinline=1";
      const autoplaySrc = `${baseSrc}&autoplay=1`;
      const observer = new IntersectionObserver(
        ([entry]) => {
          if (entry?.isIntersecting) {
            if (iframe.src !== autoplaySrc) iframe.src = autoplaySrc;
            return;
          }

          if (iframe.src !== baseSrc) iframe.src = baseSrc;
        },
        { threshold: 0.6 }
      );

      observer.observe(player);
    }
  </script>
</BaseLayout>
